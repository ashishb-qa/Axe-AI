{
  "name": "ai-rgaa-compliance-engine",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered RGAA v4.1.2 accessibility testing system using WebdriverIO, axe-core, and LLM augmentation.",
  "scripts": {
    "test:a11y": "wdio run wdio.conf.ts",
    "report:summary": "tsx scripts/print-summary.ts reports/rgaa-compliance-report.json",
    "ci:a11y": "npm run test:a11y && npm run report:summary"
  },
  "dependencies": {
    "@axe-core/webdriverio": "^4.10.2",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.10.5",
    "@wdio/cli": "^9.19.1",
    "@wdio/globals": "^9.19.1",
    "@wdio/local-runner": "^9.19.1",
    "@wdio/mocha-framework": "^9.19.1",
    "chai": "6.2.2",
    "@wdio/spec-reporter": "^9.19.1",
    "dotenv": "^16.0.0",
    "tsx": "^4.19.2",
    "typescript": "^4.9.5",
    "webdriverio": "^9.19.1"
  },
  "engines": {
    "node": ">=20"
  }
}
