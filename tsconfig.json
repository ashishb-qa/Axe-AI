{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@wdio/globals/types", "mocha"]
  },
  "include": ["src/**/*.ts", "wdio.conf.ts", "scripts/**/*.ts"]
}
